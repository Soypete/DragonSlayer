{
  "name": "gme",
  "version": "0.1.0",
  "description": "Dragonslayer \u2014 a terminal RPG where bugs are dragons and reliable code wins the kingdom",
  "type": "module",
  "bin": {
    "gme": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "dev:dungeon": "tsx src/index.tsx --repo ./practice-dungeon",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "mutation": "stryker run",
    "test:coverage": "vitest run --coverage"
  },
  "license": "MIT",
  "overrides": {
    "qs": "^6.15.2"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.12",
    "@vitest/coverage-v8": "^4.1.9",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
